PROFILE_NAME="privacy-max"
PROFILE_DESCRIPTION="High-friction maximum privacy profile for Debian-family desktops."

DNS_PROVIDER="NextDNS"
DNS_MODE="nextdns"
NEXTDNS_MODE="local-forwarder"
NEXTDNS_LISTEN_PORT="5354"

PORTMASTER_PRESET="strict"
PORTMASTER_LOCAL_DNS_MODE="forwarder"
UFW_PROFILE="locked-down"

TELEMETRY_LEVEL="strict"
SSH_HARDEN_MODE="safe"
UPDATES_MODE="security-auto"
APPARMOR_MODE="strict"
FAIL2BAN_MODE="optional"
SERVICES_PROFILE="privacy-max"
JOURNALD_PROFILE="private"
SYSCTL_PROFILE="hardened"
BROWSER_PROFILE="maximum-privacy"

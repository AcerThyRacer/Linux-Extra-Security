PROFILE_NAME="vpn-friendly"
PROFILE_DESCRIPTION="Privacy profile optimized for systems that stay behind a VPN."

DNS_PROVIDER="NextDNS"
DNS_MODE="nextdns"
NEXTDNS_MODE="local-forwarder"
NEXTDNS_LISTEN_PORT="5354"

PORTMASTER_PRESET="aggressive"
PORTMASTER_LOCAL_DNS_MODE="forwarder"
UFW_PROFILE="vpn-friendly"

TELEMETRY_LEVEL="balanced"
SSH_HARDEN_MODE="safe"
UPDATES_MODE="security-auto"
APPARMOR_MODE="on"
FAIL2BAN_MODE="off"
SERVICES_PROFILE="vpn-friendly"
JOURNALD_PROFILE="balanced"
SYSCTL_PROFILE="desktop-safe"
BROWSER_PROFILE="privacy-baseline"

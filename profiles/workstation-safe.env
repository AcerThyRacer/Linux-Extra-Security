PROFILE_NAME="workstation-safe"
PROFILE_DESCRIPTION="Workstation-safe hardening profile that preserves common developer workflows."

DNS_PROVIDER="AdGuard"
DNS_MODE="dot"
NEXTDNS_MODE=""
NEXTDNS_LISTEN_PORT="5354"

PORTMASTER_PRESET="usable"
PORTMASTER_LOCAL_DNS_MODE="off"
UFW_PROFILE="balanced"

TELEMETRY_LEVEL="balanced"
SSH_HARDEN_MODE="safe"
UPDATES_MODE="security-auto"
APPARMOR_MODE="on"
FAIL2BAN_MODE="off"
SERVICES_PROFILE="developer"
JOURNALD_PROFILE="balanced"
SYSCTL_PROFILE="desktop-safe"
BROWSER_PROFILE="developer-safe"
